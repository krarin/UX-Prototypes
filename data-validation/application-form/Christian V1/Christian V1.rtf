  \}\
\
  function setTab(el) \{\
    document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));\
    el.classList.add('active');\
  \}\
\
  function toggleContent(checkbox) \{\
    const content = document.querySelector('.filter-tabs');\
    const tableWrap = document.querySelector('.table-wrap');\
    const bulkToolbar = document.getElementById('bulkToolbar');\
    const filterTabs = document.querySelector('.filter-tabs');\
    if (checkbox.checked) \{\
      content.style.display = '';\
      tableWrap.style.display = '';\
    \} else \{\
      filterTabs.style.display = 'none';\
      tableWrap.style.display = 'none';\
      bulkToolbar.style.display = 'none';\
    \}\
  \}\
\
  // \uc0\u9472 \u9472 \u9472  NOTE WIDGET \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
  function openNoteWidget(id, event) \{\
    event.stopPropagation();\
    activeNoteId = id;\
    const row = rows.find(r => r.id === id);\
    const existing = rowNotes[id];\
    const widget = document.getElementById('noteWidget');\
    document.getElementById('noteWidgetTitle').textContent =\
      existing ? 'Notiz bearbeiten' : 'Notiz hinzuf\'fcgen';\
    document.getElementById('noteTextarea').value = existing ? existing.text : '';\
    document.getElementById('noteCheckbox').checked = existing ? existing.includeInSubmission : false;\
    widget.style.display = 'block';\
    document.getElementById('noteTextarea').focus();\
  \}\
\
  function closeNoteWidget() \{\
    document.getElementById('noteWidget').style.display = 'none';\
    activeNoteId = null;\
  \}\
\
  function saveNote() \{\
    if (activeNoteId === null) return;\
    const text = document.getElementById('noteTextarea').value.trim();\
    const include = document.getElementById('noteCheckbox').checked;\
    if (text) \{\
      rowNotes[activeNoteId] = \{ text, includeInSubmission: include \};\
    \} else \{\
      delete rowNotes[activeNoteId];\
    \}\
    closeNoteWidget();\
    renderTable();\
  \}\
\
  let openStatusId = null;\
\
  function toggleStatusDropdown(id, event) \{\
    event.stopPropagation();\
    const dd = document.getElementById(`statusDd_$\{id\}`);\
    if (!dd) return;\
    const isOpen = dd.classList.contains('open');\
    // Close any open dropdown first\
    if (openStatusId !== null) \{\
      const prev = document.getElementById(`statusDd_$\{openStatusId\}`);\
      if (prev) prev.classList.remove('open');\
    \}\
    if (isOpen) \{\
      dd.classList.remove('open');\
      openStatusId = null;\
      document.removeEventListener('mousedown', closeStatusDropdown);\
    \} else \{\
      dd.classList.add('open');\
      openStatusId = id;\
      setTimeout(() => document.addEventListener('mousedown', closeStatusDropdown), 0);\
    \}\
  \}\
\
  function closeStatusDropdown(e) \{\
    if (openStatusId === null) return;\
    const dd = document.getElementById(`statusDd_$\{openStatusId\}`);\
    if (dd && !dd.contains(e.target)) \{\
      dd.classList.remove('open');\
      openStatusId = null;\
      document.removeEventListener('mousedown', closeStatusDropdown);\
    \}\
  \}\
\
  function setStatus(id, status, event) \{\
    event.stopPropagation();\
    rowStatuses[id] = status;\
    openStatusId = null;\
    document.removeEventListener('mousedown', closeStatusDropdown);\
    renderTable();\
    updateCounts();\
  \}\
\
  function toggleLock(id, event) \{\
    event.stopPropagation();\
    if (lockedRows.has(id)) \{\
      lockedRows.delete(id);\
    \} else \{\
      lockedRows.add(id);\
    \}\
    renderTable();\
  \}\
\
  function applySystemValue(id, event) \{\
    event.stopPropagation();\
    const row = rows.find(r => r.id === id);\
    if (!row || row.systemValue === '\'96') return;\
    row.customerInput = row.systemValue;\
    manuallyEditedRows.delete(row.id);\
    syncStatus(row);\
    renderTable();\
    updateCounts();\
  \}\
\
  function syncStatus(row) \{\
    if (row.customerInput !== '\'96' && row.customerInput === row.systemValue) \{\
      rowStatuses[row.id] = 'confirmed';\
    \}\
  \}\
\
  function toggleExpand(id, event) \{\
    event.stopPropagation();\
    if (expandedRows.has(id)) \{\
      expandedRows.delete(id);\
    \} else \{\
      expandedRows.add(id);\
    \}\
    renderTable();\
  \}\
\
  function sortBy(col) \{\
    // Simple toggle sort indicator\
    renderTable();\
  \}\
\
  // \uc0\u9472 \u9472 \u9472  3-DOT MENU \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
  const pflichtfelder_set = new Set(['Vorname', 'Nachname', 'Geburtsdatum', 'Monatliches Einkommen', 'Postleitzahl', 'Stadt']);\
  const angebot_felder = new Set(['Vorname', 'Nachname', 'Monatliches Einkommen', 'Staatsangeh\'f6rigkeit', 'Postleitzahl', 'Stadt', 'Besch\'e4ftigungsart']);\
\
  let antragsphase = 'alle';\
  let pflichtfelder = 'nein';\
\
  function toggleDotMenu() \{\
    const btn = document.getElementById('dotMenuBtn');\
    const dd  = document.getElementById('dotDropdown');\
    const isOpen = dd.classList.contains('open');\
    dd.classList.toggle('open');\
    btn.classList.toggle('open');\
    if (!isOpen) \{\
      setTimeout(() => document.addEventListener('mousedown', closeDotMenuOutside), 0);\
    \}\
  \}\
\
  function closeDotMenuOutside(e) \{\
    if (!e.target.closest('.dot-menu-wrap')) \{\
      document.getElementById('dotDropdown').classList.remove('open');\
      document.getElementById('dotMenuBtn').classList.remove('open');\
      document.removeEventListener('mousedown', closeDotMenuOutside);\
    \}\
  \}\
\
  function setAntragsphase(val) \{\
    antragsphase = val;\
    updatePills();\
    renderTable();\
  \}\
\
  function setPflichtfelder(val) \{\
    pflichtfelder = val;\
    updatePills();\
    renderTable();\
  \}\
\
  function updatePills() \{\
    const wrap = document.getElementById('activePills');\
    const pills = [];\
    if (antragsphase !== 'alle') \{\
      const labels = \{ angebot: 'Angebot erstellen', einreichen: 'Antrag einreichen' \};\
      pills.push(`\
        <span class="active-pill">\
          $\{labels[antragsphase]\}\
          <span class="pill-remove" onclick="resetAntragsphase()" title="Zur\'fccksetzen">\'d7</span>\
        </span>`);\
    \}\
    if (pflichtfelder === 'ja') \{\
      pills.push(`\
        <span class="active-pill">\
          Pflichtfelder\
          <span class="pill-remove" onclick="resetPflichtfelder()" title="Zur\'fccksetzen">\'d7</span>\
        </span>`);\
    \}\
    wrap.innerHTML = pills.join('');\
  \}\
\
  function resetAntragsphase() \{\
    antragsphase = 'alle';\
    document.querySelector('input[name="antragsphase"][value="alle"]').checked = true;\
    updatePills();\
  \}\
\
  function resetPflichtfelder() \{\
    pflichtfelder = 'nein';\
    document.querySelector('input[name="pflichtfelder"][value="nein"]').checked = true;\
    updatePills();\
  \}\
\
  // \uc0\u9472 \u9472 \u9472  INLINE EDIT \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \
  let activeEditId = null;\
\
  function startEdit(id, el, event) \{\
    if (event) event.stopPropagation();\
    if (activeEditId === id) return;\
    // Close any open edit first\
    if (activeEditId !== null) commitEdit(activeEditId);\
\
    activeEditId = id;\
    const row = rows.find(r => r.id === id);\
    const currentVal = row.customerInput === '\'96' ? '' : row.customerInput;\
    const td = el.closest('td');\
\
    td.innerHTML = `\
      <div>\
        <div class="inline-edit-wrap">\
          <input\
            class="inline-input"\
            id="inlineInput_$\{id\}"\
            type="text"\
            value="$\{currentVal\}"\
            placeholder="Wert eingeben\'85"\
            onkeydown="handleEditKey(event, $\{id\})"\
            oninput="validateInline($\{id\})"\
            onfocus="this.select()"\
          />\
          <button class="inline-save-btn" onclick="commitEdit($\{id\})">\uc0\u10003 </button>\
          <button class="inline-cancel-btn" onclick="cancelEdit($\{id\})">\uc0\u10005 </button>\
        </div>\
        <div class="inline-validation-error" id="inlineError_$\{id\}" style="display:none"></div>\
      </div>`;\
\
    const input = document.getElementById(`inlineInput_$\{id\}`);\
    input.focus();\
\
    // Save on outside click\
    setTimeout(() => \{\
      document.addEventListener('mousedown', outsideClickHandler);\
    \}, 0);\
  \}\
\
  function outsideClickHandler(e) \{\
    if (!e.target.closest(`#inlineInput_$\{activeEditId\}`) &&\
        !e.target.closest('.inline-save-btn') &&\
        !e.target.closest('.inline-cancel-btn') &&\
        !e.target.closest('.inline-validation-error')) \{\
      commitEdit(activeEditId);\
    \}\
  \}\
\
  function handleEditKey(e, id) \{\
    if (e.key === 'Enter') \{ e.preventDefault(); commitEdit(id); \}\
    if (e.key === 'Escape') \{ cancelEdit(id); \}\
  \}\
\
  // Field-level validators: return error string or null\
  const fieldValidators = \{\
    'IBAN':         (val) => val.replace(/\\s/g, '').length !== 22 ? 'Die IBAN muss aus 22 Zeichen bestehen' : null,\
    'Geburtsdatum': (val) => /^\\d\{2\}\\.\\d\{2\}\\.\\d\{4\}$/.test(val) ? null : 'Das Geburtsdatum muss im Format TT.MM.JJJJ angegeben werden',\
  \};\
\
  function getValidator(id) \{\
    const row = rows.find(r => r.id === id);\
    return row ? fieldValidators[row.field] : null;\
  \}\
\
  function validateInline(id) \{\
    const input = document.getElementById(`inlineInput_$\{id\}`);\
    const errorEl = document.getElementById(`inlineError_$\{id\}`);\
    const validator = getValidator(id);\
    if (!input || !errorEl || !validator) return true;\
    const val = input.value.trim();\
    const error = val !== '' ? validator(val) : null;\
    if (error) \{\
      input.classList.add('has-error');\
      errorEl.textContent = '\uc0\u9888  ' + error;\
      errorEl.style.display = 'flex';\
    \} else \{\
      input.classList.remove('has-error');\
      errorEl.style.display = 'none';\
    \}\
    return !error;\
  \}\
\
  function commitEdit(id) \{\
    if (activeEditId !== id) return;\
    const input = document.getElementById(`inlineInput_$\{id\}`);\
    if (input) \{\
      // Block save if validation fails\
      if (!validateInline(id)) return;\
      const newVal = input.value.trim();\
      const row = rows.find(r => r.id === id);\
      row.customerInput = newVal === '' ? '\'96' : newVal;\
      if (newVal !== '' && newVal !== row.systemValue) manuallyEditedRows.add(id);\
      else manuallyEditedRows.delete(id);\
      syncStatus(row);\
      updateCounts();\
    \}\
    activeEditId = null;\
    document.removeEventListener('mousedown', outsideClickHandler);\
    renderTable();\
  \}\
\
  function cancelEdit(id) \{\
    activeEditId = null;\
    document.removeEventListener('mousedown', outsideClickHandler);\
    renderTable();\
  \}\
\
  // Initial render\
  renderTable();\
</script>\
</body>\
</html>\
}