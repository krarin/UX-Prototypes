\
  function toggleRow(id, event) \{\
    event.stopPropagation();\
    if (selectedIds.has(id)) \{\
      selectedIds.delete(id);\
    \} else \{\
      selectedIds.add(id);\
    \}\
    renderTable();\
  \}\
\
  function toggleAll() \{\
    const visible = filteredRows();\
    const allSelected = visible.every(r => selectedIds.has(r.id));\
    if (allSelected) \{\
      visible.forEach(r => selectedIds.delete(r.id));\
    \} else \{\
      visible.forEach(r => selectedIds.add(r.id));\
    \}\
    renderTable();\
  \}\
\
  function updateSelectAll() \{\
    const visible = filteredRows();\
    const cbAll = document.getElementById('cbAll');\
    const allSelected = visible.length > 0 && visible.every(r => selectedIds.has(r.id));\
    const someSelected = visible.some(r => selectedIds.has(r.id));\
    cbAll.className = 'cb cb-all';\
    if (allSelected) cbAll.className += ' checked';\
    else if (someSelected) cbAll.className += ' partial';\
  \}\
\
  function updateBulkToolbar() \{\
    const toolbar = document.getElementById('bulkToolbar');\
    const count = selectedIds.size;\
    document.getElementById('selectedCount').textContent = `$\{count\} row$\{count !== 1 ? 's' : ''\} selected`;\
    toolbar.className = count > 0 ? 'bulk-toolbar visible' : 'bulk-toolbar';\
  \}\
\
  function confirmRow(id, event) \{\
    event.stopPropagation();\
    rowStatuses[id] = 'confirmed';\
    renderTable();\
    updateCounts();\
  \}\
\
  function rejectRow(id, event) \{\
    event.stopPropagation();\
    rowStatuses[id] = 'notsure';\
    renderTable();\
    updateCounts();\
  \}\
\
  function bulkApplySystemValues() \{\
    selectedIds.forEach(id => \{\
      const row = rows.find(r => r.id === id);\
      if (row && row.systemValue !== '\'96') \{\
        row.customerInput = row.systemValue;\
        rowStatuses[id] = 'confirmed';\
      \}\
    \});\
    selectedIds.clear();\
    renderTable();\
    updateCounts();\
  \}\
\
  function clearSelection() \{\
    selectedIds.clear();\
    renderTable();\
  \}\
\
  function updateCounts() \{\
    const counts = \{ all: rows.length, error: 0, confirmed: 0, notsure: 0, unknown: 0 \};\
    rows.forEach(r => \{ counts[rowStatuses[r.id]]++; \});\
    const tabs = document.querySelectorAll('.filter-tab');\
    const labels = ['all', 'error', 'confirmed', 'notsure', 'unknown'];\
    const display = ['Alle', 'Fehler', 'Best\'e4tigt', 'Unsicher', 'Unbekannt'];\
    tabs.forEach((tab, i) => \{\
      tab.textContent = `$\{display[i]\} ($\{counts[labels[i]]\})`;\
    \});\
  \}\
\
  function setFilter(filter, el) \{\
    currentFilter = filter;\
    document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));\
    el.classList.add('active');\
    selectedIds.clear();\
    renderTable();\
  \}\
\
  function setNav(el) \{\
    document.querySelectorAll('.sidebar .nav-item').forEach(n => n.classList.remove('active'));\
