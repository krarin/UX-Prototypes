    return result;\
  \}\
\
  function renderTable() \{\
    const tbody = document.getElementById('tableBody');\
    const visible = filteredRows();\
\
    tbody.innerHTML = visible.map(row => \{\
      const st = rowStatuses[row.id];\
      const isSelected = selectedIds.has(row.id);\
      const isExpanded = expandedRows.has(row.id);\
      const hasSubRows = row.subRows && row.subRows.length > 0;\
      const dash = '<span class="dash">\'96</span>';\
      const custRaw = row.customerInput;\
      const custDisplay = custRaw === '\'96'\
        ? `<span class="editable-cell dash-editable" data-id="$\{row.id\}" onclick="startEdit($\{row.id\}, this, event)"><span class="dash">\'96</span><span class="edit-hint">\uc0\u9998 </span></span>`\
        : `<span class="editable-cell" data-id="$\{row.id\}" onclick="startEdit($\{row.id\}, this, event)">$\{custRaw\}<span class="edit-hint">\uc0\u9998 </span></span>`;\
      const sysValue = row.systemValue === '\'96' ? dash : row.systemValue;\
      const sourceHtml = row.source === '\'96'\
