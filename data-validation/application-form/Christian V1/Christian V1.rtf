\
      const mainRow = `\
        <tr class="$\{isSelected ? 'selected' : ''\}$\{hasSubRows ? ' expandable-row' : ''\}" data-id="$\{row.id\}" $\{hasSubRows ? `onclick="toggleExpand($\{row.id\}, event)"` : ''\}>\
