\
      const expandBtn = hasSubRows\
        ? `<button class="expand-btn $\{isExpanded ? 'open' : ''\}" onclick="toggleExpand($\{row.id\}, event)" title="$\{isExpanded ? 'Subzeilen ausblenden' : 'Subzeilen anzeigen'\}">$\{isExpanded ? '\uc0\u9662 ' : '\u9656 '\}</button>`\
