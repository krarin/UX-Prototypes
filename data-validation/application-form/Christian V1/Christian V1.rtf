      top: 3px; right: 3px;\
      width: 6px; height: 6px;\
      border-radius: 50%;\
      background: #f59e0b;\
      border: 1.5px solid white;\
    \}\
\
    /* Note widget */\
    .note-widget \{\
      position: fixed;\
      bottom: 24px;\
      right: 24px;\
      width: 320px;\
      background: white;\
      border: 1px solid #e5e7eb;\
      border-radius: 10px;\
      box-shadow: 0 10px 30px rgba(0,0,0,0.12), 0 2px 8px rgba(0,0,0,0.08);\
      z-index: 1000;\
      overflow: hidden;\
      animation: slideUp 0.18s ease;\
    \}\
\
    @keyframes slideUp \{\
      from \{ opacity: 0; transform: translateY(10px); \}\
      to   \{ opacity: 1; transform: translateY(0); \}\
    \}\
\
    .note-widget-header \{\
      display: flex;\
      align-items: center;\
      justify-content: space-between;\
      padding: 12px 14px;\
      border-bottom: 1px solid #f3f4f6;\
      background: #fafafa;\
    \}\
\
    .note-widget-title \{\
      display: flex;\
      align-items: center;\
      gap: 7px;\
      font-size: 13px;\
      font-weight: 600;\
      color: #111827;\
    \}\
\
    .note-widget-title svg \{ color: #6b7280; \}\
\
    .note-widget-close \{\
      background: none;\
      border: none;\
      cursor: pointer;\
      font-size: 18px;\
      color: #9ca3af;\
      line-height: 1;\
      padding: 0 2px;\
    \}\
\
    .note-widget-close:hover \{ color: #374151; \}\
\
    .note-widget-body \{ padding: 14px; \}\
\
    .note-textarea \{\
      width: 100%;\
      height: 90px;\
      border: 1px solid #d1d5db;\
      border-radius: 6px;\
      padding: 8px 10px;\
      font-size: 13px;\
      font-family: inherit;\
      color: #111827;\
      resize: none;\
      outline: none;\
      transition: border-color 0.12s, box-shadow 0.12s;\
      line-height: 1.5;\
    \}\
\
    .note-textarea:focus \{\
      border-color: #3b82f6;\
      box-shadow: 0 0 0 3px rgba(59,130,246,0.12);\
    \}\
\
    .note-checkbox-wrap \{\
      display: flex;\
      align-items: flex-start;\
      gap: 8px;\
      margin-top: 10px;\
      font-size: 12.5px;\
      color: #374151;\
      cursor: pointer;\
      line-height: 1.4;\
    \}\
\
    .note-checkbox-wrap input[type="checkbox"] \{\
      margin-top: 2px;\
      accent-color: #3b82f6;\
      cursor: pointer;\
      flex-shrink: 0;\
    \}\
\
    .note-widget-footer \{\
      display: flex;\
      justify-content: flex-end;\
      gap: 8px;\
      padding: 10px 14px;\
      border-top: 1px solid #f3f4f6;\
      background: #fafafa;\
    \}\
\
    .note-cancel-btn \{\
      padding: 6px 14px;\
      border-radius: 6px;\
      border: 1px solid #d1d5db;\
      background: white;\
      color: #6b7280;\
      font-size: 12.5px;\
      cursor: pointer;\
    \}\
\
    .note-cancel-btn:hover \{ background: #f9fafb; \}\
\
    .note-save-btn \{\
      padding: 6px 14px;\
      border-radius: 6px;\
      border: 1px solid #3b82f6;\
      background: #3b82f6;\
      color: white;\
      font-size: 12.5px;\
      font-weight: 500;\
      cursor: pointer;\
    \}\
\
    .note-save-btn:hover \{ background: #2563eb; border-color: #2563eb; \}\
\
    /* Editor initials tag */\
    .editor-tag \{\
      display: inline-flex;\
      align-items: center;\
      justify-content: center;\
      padding: 0 5px;\
      height: 20px;\
      border-radius: 4px;\
      background: transparent;\
      border: 1.5px solid #9ca3af;\
      color: #6b7280;\
      font-size: 9px;\
      font-weight: 700;\
      letter-spacing: 0.04em;\
      flex-shrink: 0;\
    \}\
\
    /* Status dropdown */\
    .status-wrap \{\
      position: relative;\
      display: inline-flex;\
      align-items: center;\
    \}\
\
    .status-wrap .badge \{\
      cursor: pointer;\
      user-select: none;\
      transition: opacity 0.12s;\
    \}\
\
    .status-wrap .badge:hover \{ opacity: 0.8; \}\
\
    .status-dropdown \{\
      display: none;\
      position: absolute;\
      top: calc(100% + 5px);\
      left: 0;\
      background: white;\
      border: 1px solid #e5e7eb;\
      border-radius: 7px;\
      box-shadow: 0 6px 20px rgba(0,0,0,0.10), 0 2px 6px rgba(0,0,0,0.06);\
      z-index: 300;\
      min-width: 140px;\
      padding: 4px;\
      animation: fadeIn 0.12s ease;\
    \}\
\
    .status-dropdown.open \{ display: block; \}\
\
    .status-option \{\
      display: flex;\
      align-items: center;\
      gap: 8px;\
      padding: 7px 10px;\
      border-radius: 5px;\
      cursor: pointer;\
      font-size: 12.5px;\
      color: #374151;\
      transition: background 0.1s;\
    \}\
\
    .status-option:hover \{ background: #f9fafb; \}\
    .status-option.current \{ background: #f3f4f6; font-weight: 600; \}\
\
    /* Lock button */\
    .lock-btn \{\
      width: 22px;\
      height: 22px;\
      border-radius: 4px;\
      border: 1px solid transparent;\
      background: none;\
      display: inline-flex;\
      align-items: center;\
      justify-content: center;\
      cursor: pointer;\
      flex-shrink: 0;\
      transition: background 0.12s, border-color 0.12s, color 0.12s;\
      padding: 0;\
    \}\
\
    .lock-btn svg \{ width: 12px; height: 12px; pointer-events: none; \}\
\
    .lock-btn.unlocked \{ color: #9ca3af; \}\
    .lock-btn.unlocked:hover \{ background: #f3f4f6; border-color: #d1d5db; color: #6b7280; \}\
\
    .lock-btn.locked \{ color: #059669; \}\
    .lock-btn.locked:hover \{ background: #d1fae5; border-color: #6ee7b7; color: #047857; \}\
\
    /* Overwrite button */\
    .overwrite-btn \{\
      width: 24px;\
      height: 24px;\
      border-radius: 5px;\
      border: 1px solid #d1d5db;\
      background: white;\
      color: #6b7280;\
      display: inline-flex;\
      align-items: center;\
      justify-content: center;\
      cursor: pointer;\
      flex-shrink: 0;\
      transition: background 0.12s, border-color 0.12s, color 0.12s;\
      vertical-align: middle;\
    \}\
\
    .overwrite-btn:hover:not(:disabled) \{\
      background: #eff6ff;\
      border-color: #93c5fd;\
      color: #2563eb;\
    \}\
\
    .overwrite-btn:disabled \{\
      opacity: 0.3;\
      cursor: not-allowed;\
    \}\
\
    .overwrite-btn svg \{ width: 12px; height: 12px; pointer-events: none; \}\
\
    .sys-value-cell \{\
      display: flex;\
      align-items: center;\
      gap: 7px;\
    \}\
\
    /* Inline edit */\
    .editable-cell \{\
      cursor: text;\
      border-radius: 4px;\
      padding: 2px 4px;\
      margin: -2px -4px;\
      min-width: 80px;\
      display: inline-block;\
    \}\
\
    .editable-cell:hover \{\
      background: #f0f9ff;\
      outline: 1px dashed #93c5fd;\
    \}\
\
    .editable-cell .edit-hint \{\
      display: none;\
      margin-left: 5px;\
      color: #93c5fd;\
      font-size: 11px;\
    \}\
\
    .editable-cell:hover .edit-hint \{ display: inline; \}\
\
    .inline-input \{\
      border: 1.5px solid #3b82f6;\
      border-radius: 5px;\
      padding: 4px 8px;\
      font-size: 13px;\
      font-family: inherit;\
      color: #111827;\
      background: white;\
      outline: none;\
      width: 100%;\
      min-width: 120px;\
      box-shadow: 0 0 0 3px rgba(59,130,246,0.15);\
    \}\
\
    .inline-input:focus \{ border-color: #2563eb; \}\
\
    .inline-edit-wrap \{\
      display: flex;\
      align-items: center;\
      gap: 5px;\
    \}\
\
    .inline-save-btn \{\
      padding: 3px 8px;\
      border-radius: 4px;\
      font-size: 11.5px;\
      font-weight: 600;\
      cursor: pointer;\
      border: 1px solid #6ee7b7;\
      background: #d1fae5;\
      color: #065f46;\
      white-space: nowrap;\
      flex-shrink: 0;\
    \}\
\
    .inline-save-btn:hover \{ background: #a7f3d0; \}\
\
    .inline-cancel-btn \{\
      padding: 3px 8px;\
      border-radius: 4px;\
      font-size: 11.5px;\
      cursor: pointer;\
      border: 1px solid #e5e7eb;\
      background: white;\
      color: #9ca3af;\
      flex-shrink: 0;\
    \}\
\
    .inline-cancel-btn:hover \{ background: #f3f4f6; color: #6b7280; \}\
\
    .inline-validation-error \{\
      font-size: 11.5px;\
      color: #dc2626;\
      margin-top: 5px;\
      display: flex;\
      align-items: center;\
      gap: 4px;\
    \}\
\
    .inline-input.has-error \{\
      border-color: #dc2626;\
      box-shadow: 0 0 0 3px rgba(220,38,38,0.12);\
    \}\
\
    /* Scrollbar styling */\
    .content::-webkit-scrollbar \{ width: 6px; \}\
    .content::-webkit-scrollbar-track \{ background: transparent; \}\
    .content::-webkit-scrollbar-thumb \{ background: #d1d5db; border-radius: 3px; \}\
\
    /* Responsive notice bar hidden */\
    .notify-hidden \{ display: none; \}\
\
    /* Action toolbar (appears when rows selected) */\
    .bulk-toolbar \{\
      display: none;\
      align-items: center;\
      gap: 10px;\
      padding: 10px 16px;\
      background: #eff6ff;\
      border-bottom: 1px solid #bfdbfe;\
      font-size: 12.5px;\
      color: #1d4ed8;\
      font-weight: 500;\
    \}\
\
    .bulk-toolbar.visible \{ display: flex; \}\
\
    .bulk-btn \{\
      padding: 5px 12px;\
      border-radius: 5px;\
      font-size: 12px;\
      font-weight: 500;\
      cursor: pointer;\
      border: 1px solid;\
    \}\
\
    .bulk-confirm \{ background: #d1fae5; border-color: #6ee7b7; color: #065f46; \}\
    .bulk-confirm:hover \{ background: #a7f3d0; \}\
    .bulk-reject \{ background: white; border-color: #e5e7eb; color: #6b7280; \}\
    .bulk-reject:hover \{ background: #fee2e2; border-color: #fca5a5; color: #dc2626; \}\
\
    .bulk-clear \{ margin-left: auto; cursor: pointer; color: #6b7280; font-size: 12px; \}\
    .bulk-clear:hover \{ color: #374151; text-decoration: underline; \}\
\
    /* User avatar area in top right */\
    .topbar-right \{\
      display: flex;\
      align-items: center;\
      gap: 10px;\
      padding: 8px 24px 8px;\
      background: white;\
      border-bottom: 1px solid #e5e7ef;\
      justify-content: flex-end;\
      font-size: 12.5px;\
      color: #374151;\
    \}\
\
    .topbar-right .user-info \{\
      display: flex;\
      align-items: center;\
      gap: 8px;\
    \}\
\
    .topbar-right .avatar \{\
      width: 28px;\
      height: 28px;\
      border-radius: 50%;\
      background: #3b82f6;\
      color: white;\
      display: flex;\
      align-items: center;\
      justify-content: center;\
      font-size: 11px;\
      font-weight: 700;\
    \}\
\
    .topbar-right .icon-btn \{\
      width: 28px;\
      height: 28px;\
      display: flex;\
      align-items: center;\
      justify-content: center;\
      border-radius: 6px;\
      cursor: pointer;\
      color: #6b7280;\
      position: relative;\
    \}\
\
    .topbar-right .icon-btn:hover \{ background: #f3f4f6; \}\
\
    .topbar-right .notif-badge \{\
      position: absolute;\
      top: 2px; right: 2px;\
      width: 14px; height: 14px;\
      border-radius: 50%;\
      background: #ef4444;\
      color: white;\
      font-size: 8px;\
      font-weight: 700;\
      display: flex;\
      align-items: center;\
      justify-content: center;\
    \}\
  </style>\
</head>\
